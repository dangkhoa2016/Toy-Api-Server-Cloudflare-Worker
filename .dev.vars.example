# ============================================
# 🧪 Local Development Variables (.dev.vars)
# Loaded by `wrangler dev` and should NOT be committed
# ============================================

# Runtime mode for local execution.
NODE_ENV=development

# Allowed browser origins for CORS during development.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173

# Prefix added before all KV keys to isolate this service in shared namespaces.
CLOUDFLARE_KV_PREFIX=toy-api-server

# Adds security response headers (nosniff, frame options, referrer policy).
SECURITY_HEADERS_ENABLED=true

# App label for logs/debug output.
APP_NAME=toy-api-dev

# Basic auth switch. Keep false for normal local development.
BASIC_AUTH_ENABLED=false

# Credentials are only used when BASIC_AUTH_ENABLED=true.
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me

# Realm text shown by browser auth prompt.
BASIC_AUTH_REALM=Toy API Dev

# -----------------
# Anti-abuse policy
# -----------------

# Enable/disable per-IP rate limit for POST /api/toys.
RATE_LIMIT_ENABLED=true

# Max POST /api/toys requests allowed per rate-limit window.
RATE_LIMIT_MAX=20

# Rate-limit window length in milliseconds.
RATE_LIMIT_WINDOW_MS=300000

# Global cap for active toys across all clients.
MAX_ACTIVE_TOYS_GLOBAL=500

# Default active toy quota per client IP.
MAX_TOYS_PER_IP=5

# Expanded per-IP quota during seed window.
SEED_MAX_TOYS_PER_IP=15

# Seed window duration in milliseconds.
SEED_WINDOW_MS=600000

# Toy lifetime (TTL) in milliseconds.
TOY_TTL_MS=900000

# Cleanup scheduler interval in milliseconds.
TOY_CLEANUP_INTERVAL_MS=120000
