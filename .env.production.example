# ============================================
# 🌐 Production Environment Variables
# Copy to .env.production (DO NOT COMMIT)
# ============================================

# Required by deploy.js route/kv injection flow.

# Root Cloudflare zone (no trailing slash). Used as zone_name in generated route.
DOMAIN=myapp.com

# API hostname prefix. Final host is <API_SUBDOMAIN>.<DOMAIN>.
API_SUBDOMAIN=api

# CORS (comma-separated if multiple)
CORS_ORIGINS=https://myapp.com

# KV namespace ID (from wrangler kv create)
KV_NAMESPACE_ID=xxxxxxxxxxxxxxxxxxxx

# Runtime app label (for logs/debug output)
APP_NAME=toy-api-server

# Security header switch.
SECURITY_HEADERS_ENABLED=true

# Basic auth policy for production runtime.
BASIC_AUTH_ENABLED=false
BASIC_AUTH_REALM=Protected API

# Credentials required when BASIC_AUTH_ENABLED=true.
# In production, prefer storing these as Wrangler secrets.
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me

# -----------------
# Anti-abuse policy
# -----------------

# Enable/disable per-IP rate limit for POST /api/toys.
RATE_LIMIT_ENABLED=true

# Max POST /api/toys requests allowed per rate-limit window.
RATE_LIMIT_MAX=20

# Rate-limit window length in milliseconds.
RATE_LIMIT_WINDOW_MS=300000

# Global cap for active toys across all clients.
MAX_ACTIVE_TOYS_GLOBAL=500

# Default active toy quota per client IP.
MAX_TOYS_PER_IP=5

# Expanded per-IP quota during seed window.
SEED_MAX_TOYS_PER_IP=15

# Seed window duration in milliseconds.
SEED_WINDOW_MS=600000

# Toy lifetime (TTL) in milliseconds.
TOY_TTL_MS=900000

# Cleanup scheduler interval in milliseconds.
TOY_CLEANUP_INTERVAL_MS=120000
