# ============================================
# 🧪 Staging Environment Variables
# Copy to .env.staging (DO NOT COMMIT)
# ============================================

# Root Cloudflare zone.
DOMAIN=myapp.com

# API hostname prefix. Final host is <API_SUBDOMAIN>.<DOMAIN>.
API_SUBDOMAIN=staging

# Allowed CORS origin(s) for staging frontend(s).
CORS_ORIGINS=https://staging.myapp.com

# Staging KV namespace ID for binding TOY_STATE.
KV_NAMESPACE_ID=staging_kv_id_here

# Runtime app label.
APP_NAME=toy-api-staging

# Security header switch.
SECURITY_HEADERS_ENABLED=true

# Optional staging basic auth hardening.
BASIC_AUTH_ENABLED=true
BASIC_AUTH_REALM=Toy API Staging
BASIC_AUTH_USERNAME=staging-admin
BASIC_AUTH_PASSWORD=change-me
